<script>

/* =========================================
   SETTINGS
========================================= */

const API_URL =
    "https://apiv2.nobitex.ir/v3/orderbook/USDTIRT";

const PRICE_DIVISOR = 10;

const ANNUAL_BANK_RATE = 40;


/* =========================================
   TRANSACTIONS
========================================= */

const transactions = [

    {
        date: "1405/02/13",
        type: "buy",
        amount: 300,
        price: 187000
    },

    {
        date: "1405/02/17",
        type: "buy",
        amount: 1100,
        price: 174000
    },

    {
        date: "1405/02/20",
        type: "buy",
        amount: 1000,
        price: 177500
    },

    {
        date: "1405/02/26",
        type: "buy",
        amount: 1000,
        price: 181500
    },

    {
        date: "1405/02/29",
        type: "buy",
        amount: 1100,
        price: 177000
    },

    {
        date: "1405/02/30",
        type: "buy",
        amount: 2200,
        price: 180000
    },

    {
        date: "1405/03/02",
        type: "buy",
        amount: 600,
        price: 179167
    },

    {
        date: "1405/03/26",
        type: "buy",
        amount: 2500,
        price: 158160
    },

    {
        date: "1405/04/31",
        type: "sell",
        amount: 2500,
        price: 190160
    }

];


/* =========================================
   FORMAT
========================================= */

function formatNumber(value) {

    if (
        !Number.isFinite(value)
    ) {
        return "-";
    }

    return Math.round(value)
        .toLocaleString("en-US");

}


function formatPercent(value) {

    if (
        !Number.isFinite(value)
    ) {
        return "-";
    }

    return (
        value >= 0 ? "+" : ""
    )
    +
    value.toFixed(2)
    +
    "%";

}


/* =========================================
   DATE
========================================= */

function parseJalaliDate(date) {

    const p =
        date.split("/").map(Number);

    return {
        y: p[0],
        m: p[1],
        d: p[2]
    };

}


function jalaliToGregorian(
    jy,
    jm,
    jd
) {

    jy -= 979;

    let days =
        365 * jy
        +
        Math.floor(jy / 33) * 8
        +
        Math.floor(
            ((jy % 33) + 3) / 4
        );

    for (
        let i = 1;
        i < jm;
        i++
    ) {

        days +=
            i <= 6 ? 31 : 30;

    }

    days += jd - 1;

    let gy =
        1600
        +
        400 *
        Math.floor(
            days / 146097
        );

    days %= 146097;

    if (days > 36524) {

        gy +=
            100 *
            Math.floor(
                --days / 36524
            );

        days %= 36524;

        if (days >= 365) {
            days++;
        }

    }

    gy +=
        4 *
        Math.floor(
            days / 1461
        );

    days %= 1461;

    if (days > 365) {

        gy +=
            Math.floor(
                (days - 1) / 365
            );

        days =
            (days - 1) % 365;

    }

    let gd =
        days + 1;

    const leap =
        (
            gy % 4 === 0
            &&
            gy % 100 !== 0
        )
        ||
        gy % 400 === 0;

    const monthDays = [

        0,
        31,
        leap ? 29 : 28,
        31,
        30,
        31,
        30,
        31,
        31,
        30,
        31,
        30,
        31

    ];

    let gm = 1;

    while (
        gd >
        monthDays[gm]
    ) {

        gd -=
            monthDays[gm];

        gm++;

    }

    return new Date(
        gy,
        gm - 1,
        gd
    );

}


function daysBetween(
    start,
    end
) {

    const s =
        parseJalaliDate(start);

    const e =
        parseJalaliDate(end);

    const startDate =
        jalaliToGregorian(
            s.y,
            s.m,
            s.d
        );

    const endDate =
        jalaliToGregorian(
            e.y,
            e.m,
            e.d
        );

    return Math.max(
        1,
        Math.round(
            (
                endDate -
                startDate
            )
            /
            86400000
        )
        +
        1
    );

}


/* =========================================
   TODAY JALALI
========================================= */

function getTodayJalali() {

    const now =
        new Date();

    const gy =
        now.getFullYear();

    const gm =
        now.getMonth() + 1;

    const gd =
        now.getDate();

    let jy =
        gy - 621;

    let days =
        (
            gm <= 2
            ?
            0
            :
            31
        );

    for (
        let i = 1;
        i < gm;
        i++
    ) {

        days +=
            [
                31,
                28,
                31,
                30,
                31,
                30,
                31,
                31,
                30,
                31,
                30,
                31
            ][i - 1];

    }

    days += gd;

    let offset =
        days -
        80;

    if (
        offset <= 0
    ) {

        jy--;

    }

    /*
       For this dashboard,
       today's real Gregorian date
       is converted using Intl.
    */

    try {

        const formatter =
            new Intl.DateTimeFormat(
                "fa-IR-u-ca-persian",
                {
                    year: "numeric",
                    month: "2-digit",
                    day: "2-digit"
                }
            );

        return formatter.format(
            now
        );

    }

    catch {

        return "-";

    }

}


/* =========================================
   BANK VALUE
========================================= */

function bankValue(
    principal,
    startDate,
    today
) {

    const days =
        daysBetween(
            startDate,
            today
        );

    const dailyRate =
        ANNUAL_BANK_RATE
        /
        100
        /
        365;

    return (
        principal
        *
        Math.pow(
            1 + dailyRate,
            days
        )
    );

}


/* =========================================
   FIFO
========================================= */

function calculateFIFO(
    list,
    currentPrice,
    today
) {

    const lots = [];

    let inCount = 0;

    let outCount = 0;


    for (
        const t of list
    ) {

        const amount =
            Number(t.amount);

        const price =
            Number(t.price);


        if (
            t.type === "buy"
        ) {

            inCount++;

            lots.push({

                amount:
                    amount,

                price:
                    price,

                date:
                    t.date

            });

        }


        else if (
            t.type === "sell"
        ) {

            outCount++;

            let remaining =
                amount;


            while (
                remaining > 0
                &&
                lots.length > 0
            ) {

                if (
                    lots[0].amount
                    <=
                    remaining
                ) {

                    remaining -=
                        lots[0].amount;

                    lots.shift();

                }

                else {

                    lots[0].amount -=
                        remaining;

                    remaining = 0;

                }

            }

        }

    }


    let quantity = 0;

    let paid = 0;

    let bank = 0;


    for (
        const lot of lots
    ) {

        quantity +=
            lot.amount;


        paid +=
            lot.amount *
            lot.price;


        bank +=
            bankValue(
                lot.amount *
                lot.price,
                lot.date,
                today
            );

    }


    const average =
        quantity > 0
        ?
        paid / quantity
        :
        0;


    const value =
        quantity *
        currentPrice;


    const adjusted =
        quantity > 0
        ?
        bank / quantity
        :
        0;


    const plPurchase =
        average > 0
        ?
        (
            (
                currentPrice -
                average
            )
            /
            average
        )
        *
        100
        :
        0;


    const plBank =
        bank > 0
        ?
        (
            (
                value -
                bank
            )
            /
            bank
        )
        *
        100
        :
        0;


    return {

        quantity,
        paid,
        average,
        value,
        bank,
        adjusted,
        plPurchase,
        plBank,
        difference:
            value - bank,
        inCount,
        outCount

    };

}


/* =========================================
   RENDER
========================================= */

function render(
    result,
    prefix,
    currentPrice
) {

    document.getElementById(
        prefix + "Average"
    ).textContent =
        formatNumber(
            result.average
        );


    document.getElementById(
        prefix + "Paid"
    ).textContent =
        formatNumber(
            result.paid
        );


    document.getElementById(
        prefix + "Adjusted"
    ).textContent =
        formatNumber(
            result.adjusted
        );


    document.getElementById(
        prefix + "Quantity"
    ).textContent =
        formatNumber(
            result.quantity
        );


    document.getElementById(
        prefix + "Value"
    ).textContent =
        formatNumber(
            result.value
        );


    document.getElementById(
        prefix + "Bank"
    ).textContent =
        formatNumber(
            result.bank
        );


    document.getElementById(
        prefix + "Difference"
    ).textContent =
        formatNumber(
            Math.abs(
                result.difference
            )
        );


    document.getElementById(
        prefix + "PLPurchase"
    ).textContent =
        formatPercent(
            result.plPurchase
        );


    document.getElementById(
        prefix + "PLBank"
    ).textContent =
        formatPercent(
            result.plBank
        );


    document.getElementById(
        prefix + "PLPurchase"
    ).className =
        "pl-value " +
        (
            result.plPurchase >= 0
            ?
            "profit"
            :
            "loss"
        );


    document.getElementById(
        prefix + "PLBank"
    ).className =
        "pl-value " +
        (
            result.plBank >= 0
            ?
            "profit"
            :
            "loss"
        );


    const main =
        document.getElementById(
            prefix + "MainPrice"
        );


    const message =
        document.getElementById(
            prefix + "Result"
        );


    main.classList.remove(
        "status-green",
        "status-red"
    );


    if (
        result.adjusted
        <
        currentPrice
    ) {

        main.classList.add(
            "status-green"
        );

        message.textContent =
            "INVESTMENT IS BETTER THAN BANK";

        message.style.color =
            "#34d399";

    }

    else {

        main.classList.add(
            "status-red"
        );

        message.textContent =
            "BANK RETURN IS BETTER THAN INVESTMENT";

        message.style.color =
            "#f87171";

    }


    const trades =
        document.getElementById(
            prefix + "Trades"
        );


    if (trades) {

        trades.textContent =
            result.inCount
            +
            " IN  •  "
            +
            result.outCount
            +
            " OUT";

    }

}


/* =========================================
   LIVE PRICE
========================================= */

async function loadPrice() {

    const response =
        await fetch(
            API_URL
            +
            "?_="
            +
            Date.now(),
            {
                method: "GET",
                cache: "no-store"
            }
        );


    if (
        !response.ok
    ) {

        throw new Error(
            "Nobitex API Error: "
            +
            response.status
        );

    }


    const data =
        await response.json();


    /*
       IMPORTANT:
       Nobitex returns lastTradePrice
       in Rial.

       Divide by 10
       to display Toman.
    */

    const price =
        Number(
            data.lastTradePrice
        )
        /
        PRICE_DIVISOR;


    if (
        !Number.isFinite(price)
        ||
        price <= 0
    ) {

        throw new Error(
            "Invalid lastTradePrice"
        );

    }


    return price;

}


/* =========================================
   MAIN
========================================= */

async function main() {

    try {

        document.getElementById(
            "today"
        ).textContent =
            getTodayJalali();


        document.getElementById(
            "bankRate"
        ).textContent =
            ANNUAL_BANK_RATE
            +
            "%";


        /*
           Live price
        */

        const currentPrice =
            await loadPrice();


        document.getElementById(
            "currentPrice"
        ).textContent =
            formatNumber(
                currentPrice
            );


        /*
           Overall

           همه تراکنش‌ها
           فروش 2500 هم لحاظ می‌شود
        */

        const overall =
            calculateFIFO(
                transactions,
                currentPrice,
                getTodayJalali()
            );


        render(
            overall,
            "overall",
            currentPrice
        );


        /*
           Last 6

           شش تراکنش آخر
           شامل OUT آخر
        */

        const lastSix =
            transactions.slice(-6);


        const six =
            calculateFIFO(
                lastSix,
                currentPrice,
                getTodayJalali()
            );


        render(
            six,
            "six",
            currentPrice
        );


        /*
           Last Period

           اگر آخرین تراکنش OUT باشد:
           از آخرین IN شروع می‌کنیم
           اما OUT را هم نگه می‌داریم.
        */

        const last =
            transactions[
                transactions.length - 1
            ];


        let startIndex =
            transactions.length - 1;


        if (
            last.type === "sell"
        ) {

            for (
                let i =
                    transactions.length - 1;

                i >= 0;

                i--
            ) {

                if (
                    transactions[i].type
                    ===
                    "buy"
                ) {

                    startIndex =
                        i;

                    break;

                }

            }

        }


        const lastPeriodTransactions =
            transactions.slice(
                startIndex
            );


        const lastPeriod =
            calculateFIFO(
                lastPeriodTransactions,
                currentPrice,
                getTodayJalali()
            );


        render(
            lastPeriod,
            "last",
            currentPrice
        );


        /*
           Last Action
        */

        const action =
            document.getElementById(
                "lastAction"
            );


        if (
            last.type === "sell"
        ) {

            action.textContent =
                "OUT";

            action.className =
                "action-badge action-out";


            document.getElementById(
                "lastResult"
            ).textContent =
                "LAST PERIOD WAS OUT";


            document.getElementById(
                "lastResult"
            ).style.color =
                "#fbbf24";

        }

        else {

            action.textContent =
                "IN";

            action.className =
                "action-badge action-in";

        }

    }

    catch (error) {

        console.error(
            error
        );


        document.getElementById(
            "currentPrice"
        ).textContent =
            "Unavailable";


        document.getElementById(
            "errorBox"
        ).innerHTML =

            '<div class="error">' +

            error.message +

            '<br><small>' +

            'اگر قیمت آنلاین نمایش داده نمی‌شود، احتمالاً API نوبیتکس توسط مرورگر به دلیل CORS مسدود شده است.' +

            '</small>' +

            '</div>';

    }

}


main();

</script>

