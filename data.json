<script>

/* =========================
   FORMAT
========================= */

function formatNumber(value) {

    if (!isFinite(value)) {
        return "-";
    }

    return Math.round(value)
        .toLocaleString("en-US");
}


function formatPercent(value) {

    if (!isFinite(value)) {
        return "-";
    }

    const sign = value > 0 ? "+" : "";

    return sign + value.toFixed(2) + "%";
}


/* =========================
   JALALI DATE
========================= */

function jalaliToGregorian(jy, jm, jd) {

    jy -= 979;

    let days =
        365 * jy +
        Math.floor(jy / 33) * 8 +
        Math.floor(((jy % 33) + 3) / 4);

    for (let i = 1; i < jm; i++) {

        days += i <= 6 ? 31 : 30;

    }

    days += jd - 1;

    let gy =
        1600 +
        400 * Math.floor(days / 146097);

    days %= 146097;

    if (days > 36524) {

        gy +=
            100 *
            Math.floor(--days / 36524);

        days %= 36524;

        if (days >= 365) {
            days++;
        }

    }

    gy +=
        4 *
        Math.floor(days / 1461);

    days %= 1461;

    if (days > 365) {

        gy +=
            Math.floor((days - 1) / 365);

        days =
            (days - 1) % 365;

    }

    let gd = days + 1;

    const leap =
        (
            gy % 4 === 0 &&
            gy % 100 !== 0
        )
        ||
        gy % 400 === 0;

    const monthDays = [

        0,
        31,
        leap ? 29 : 28,
        31,
        30,
        31,
        30,
        31,
        31,
        30,
        31,
        30,
        31

    ];

    let gm = 1;

    while (
        gd > monthDays[gm]
    ) {

        gd -= monthDays[gm];

        gm++;

    }

    return new Date(
        gy,
        gm - 1,
        gd
    );
}


function daysBetweenInclusive(start, end) {

    const s =
        start.split("/").map(Number);

    const e =
        end.split("/").map(Number);

    const startDate =
        jalaliToGregorian(
            s[0],
            s[1],
            s[2]
        );

    const endDate =
        jalaliToGregorian(
            e[0],
            e[1],
            e[2]
        );

    return Math.floor(
        (endDate - startDate) /
        86400000
    ) + 1;
}


function dateNumber(date) {

    const p =
        date.split("/").map(Number);

    return (
        p[0] * 10000 +
        p[1] * 100 +
        p[2]
    );
}


/* =========================
   TODAY JALALI
========================= */

function getTodayJalali() {

    const now = new Date();

    const gy = now.getFullYear();

    const gm = now.getMonth() + 1;

    const gd = now.getDate();

    const gdm = [
        0,31,59,90,120,151,
        181,212,243,273,304,334
    ];

    let jy =
        gy > 1600 ? 979 : 0;

    const y =
        gy > 1600
        ? gy - 1600
        : gy - 621;

    let days =
        365 * y +
        Math.floor((y + 3) / 4) -
        Math.floor((y + 99) / 100) +
        Math.floor((y + 399) / 400) -
        80 +
        gd +
        gdm[gm - 1];

    jy +=
        33 *
        Math.floor(days / 12053);

    days %= 12053;

    jy +=
        4 *
        Math.floor(days / 1461);

    days %= 1461;

    if (days > 365) {

        jy +=
            Math.floor((days - 1) / 365);

        days =
            (days - 1) % 365;

    }

    let jm;
    let jd;

    if (days < 186) {

        jm =
            1 +
            Math.floor(days / 31);

        jd =
            1 +
            days % 31;

    } else {

        jm =
            7 +
            Math.floor((days - 186) / 30);

        jd =
            1 +
            (days - 186) % 30;

    }

    return (
        jy +
        "/" +
        String(jm).padStart(2,"0") +
        "/" +
        String(jd).padStart(2,"0")
    );
}


/* =========================
   BANK INTEREST
========================= */

function compoundValue(
    principal,
    startDate,
    today,
    annualRate
) {

    const days =
        daysBetweenInclusive(
            startDate,
            today
        );

    const dailyRate =
        annualRate / 100 / 365;

    return (
        principal *
        Math.pow(
            1 + dailyRate,
            days
        )
    );
}


/* =========================
   FIFO
========================= */

function calculateFIFO(
    transactions,
    currentPrice,
    today,
    annualRate
) {

    let lots = [];

    let buyCount = 0;

    let sellCount = 0;

    for (const t of transactions) {

        const amount =
            Number(t.amount);

        const price =
            Number(t.price);

        if (t.type === "buy") {

            buyCount++;

            lots.push({
                amount,
                price,
                date: t.date
            });

        }

        else if (t.type === "sell") {

            sellCount++;

            let remaining = amount;

            while (
                remaining > 0 &&
                lots.length > 0
            ) {

                const lot = lots[0];

                if (
                    lot.amount <= remaining
                ) {

                    remaining -=
                        lot.amount;

                    lots.shift();

                }

                else {

                    lot.amount -=
                        remaining;

                    remaining = 0;

                }

            }

        }

    }


    const currentQuantity =
        lots.reduce(
            (sum, lot) =>
                sum + lot.amount,
            0
        );


    const paidAmount =
        lots.reduce(
            (sum, lot) =>
                sum +
                lot.amount *
                lot.price,
            0
        );


    const averagePurchasePrice =
        currentQuantity > 0
        ?
        paidAmount /
        currentQuantity
        :
        0;


    let bankValue = 0;

    for (const lot of lots) {

        bankValue +=
            compoundValue(
                lot.amount *
                lot.price,
                lot.date,
                today,
                annualRate
            );

    }


    const currentValue =
        currentQuantity *
        currentPrice;


    const bankAdjustedPrice =
        currentQuantity > 0
        ?
        bankValue /
        currentQuantity
        :
        0;


    const plPurchase =
        averagePurchasePrice > 0
        ?
        (
            (
                currentPrice -
                averagePurchasePrice
            )
            /
            averagePurchasePrice
        ) * 100
        :
        0;


    const plBank =
        bankValue > 0
        ?
        (
            (
                currentValue -
                bankValue
            )
            /
            bankValue
        ) * 100
        :
        0;


    return {

        currentQuantity,

        paidAmount,

        averagePurchasePrice,

        bankAdjustedPrice,

        currentValue,

        bankValue,

        difference:
            currentValue -
            bankValue,

        plPurchase,

        plBank,

        buyCount,

        sellCount,

        lots

    };

}


/* =========================
   LAST ACTIVE PURCHASE
========================= */

function getLastActiveLot(transactions) {

    let lots = [];

    for (const t of transactions) {

        const amount =
            Number(t.amount);

        const price =
            Number(t.price);

        if (t.type === "buy") {

            lots.push({

                amount,

                price,

                date: t.date

            });

        }

        else if (t.type === "sell") {

            let remaining =
                amount;

            while (
                remaining > 0 &&
                lots.length > 0
            ) {

                const lot =
                    lots[0];

                if (
                    lot.amount <=
                    remaining
                ) {

                    remaining -=
                        lot.amount;

                    lots.shift();

                }

                else {

                    lot.amount -=
                        remaining;

                    remaining = 0;

                }

            }

        }

    }

    if (
        lots.length === 0
    ) {

        return null;

    }

    return lots[
        lots.length - 1
    ];
}


/* =========================
   DISPLAY
========================= */

function displaySection(
    result,
    prefix
) {

    document.getElementById(
        prefix + "Average"
    ).textContent =
        formatNumber(
            result.averagePurchasePrice
        );


    document.getElementById(
        prefix + "Paid"
    ).textContent =
        formatNumber(
            result.paidAmount
        );


    document.getElementById(
        prefix + "Adjusted"
    ).textContent =
        formatNumber(
            result.bankAdjustedPrice
        );


    document.getElementById(
        prefix + "Quantity"
    ).textContent =
        formatNumber(
            result.currentQuantity
        );


    document.getElementById(
        prefix + "Value"
    ).textContent =
        formatNumber(
            result.currentValue
        );


    document.getElementById(
        prefix + "Bank"
    ).textContent =
        formatNumber(
            result.bankValue
        );


    document.getElementById(
        prefix + "Difference"
    ).textContent =
        formatNumber(
            Math.abs(
                result.difference
            )
        );


    const plPurchase =
        document.getElementById(
            prefix +
            "PLPurchase"
        );


    const plBank =
        document.getElementById(
            prefix +
            "PLBank"
        );


    plPurchase.textContent =
        formatPercent(
            result.plPurchase
        );


    plBank.textContent =
        formatPercent(
            result.plBank
        );


    plPurchase.className =
        "pl-value " +
        (
            result.plPurchase >= 0
            ?
            "profit"
            :
            "loss"
        );


    plBank.className =
        "pl-value " +
        (
            result.plBank >= 0
            ?
            "profit"
            :
            "loss"
        );


    const mainPrice =
        document.getElementById(
            prefix +
            "MainPrice"
        );


    const resultBox =
        document.getElementById(
            prefix +
            "Result"
        );


    mainPrice.classList.remove(
        "status-green",
        "status-red"
    );


    if (
        result.bankAdjustedPrice <
        result.currentPrice
    ) {

        mainPrice.classList.add(
            "status-green"
        );

        resultBox.textContent =
            "INVESTMENT IS BETTER THAN BANK";

        resultBox.style.color =
            "#34d399";

    }

    else {

        mainPrice.classList.add(
            "status-red"
        );

        resultBox.textContent =
            "BANK RETURN IS BETTER THAN INVESTMENT";

        resultBox.style.color =
            "#f87171";

    }


    const tradeCount =
        document.getElementById(
            prefix +
            "Trades"
        );


    if (tradeCount) {

        tradeCount.textContent =
            result.buyCount +
            " IN  •  " +
            result.sellCount +
            " OUT";

    }

}


/* =========================
   NOBITEX PRICE
========================= */

async function getCurrentPrice(
    apiUrl,
    divisor
) {

    const response =
        await fetch(
            apiUrl,
            {
                method: "GET",
                headers: {
                    "Accept":
                        "application/json"
                },
                cache: "no-store"
            }
        );


    if (!response.ok) {

        throw new Error(
            "Unable to get current price"
        );

    }


    const data =
        await response.json();


    if (
        !data.lastTradePrice
    ) {

        throw new Error(
            "Invalid lastTradePrice"
        );

    }


    return (
        Number(
            data.lastTradePrice
        ) /
        divisor
    );

}


/* =========================
   INIT
========================= */

async function init() {

    const dataResponse =
        await fetch(
            "data.json?x=" +
            Date.now()
        );


    if (!dataResponse.ok) {

        throw new Error(
            "Cannot load data.json"
        );

    }


    const data =
        await dataResponse.json();


    const annualBankRate =
        Number(
            data.annualBankRate || 40
        );


    const divisor =
        Number(
            data.priceDivisor || 10
        );


    const currentPrice =
        await getCurrentPrice(
            data.priceApi,
            divisor
        );


    const today =
        getTodayJalali();


    document.getElementById(
        "today"
    ).textContent =
        today;


    document.getElementById(
        "currentPrice"
    ).textContent =
        formatNumber(
            currentPrice
        );


    document.getElementById(
        "bankRate"
    ).textContent =
        annualBankRate +
        "%";


    const transactions =
        data.transactions
        .slice()
        .sort(
            (a,b) =>
                dateNumber(a.date) -
                dateNumber(b.date)
        );


    /* OVERALL */

    const overall =
        calculateFIFO(
            transactions,
            currentPrice,
            today,
            annualBankRate
        );


    displaySection(
        overall,
        "overall"
    );


    /* LAST 6 PERIODS */

    const sixTransactions =
        transactions.slice(-6);


    const six =
        calculateFIFO(
            sixTransactions,
            currentPrice,
            today,
            annualBankRate
        );


    displaySection(
        six,
        "six"
    );


    /* LAST PERIOD */

    const lastActiveLot =
        getLastActiveLot(
            transactions
        );


    if (
        lastActiveLot
    ) {

        const lastPeriod =
            calculateFIFO(
                [
                    {
                        date:
                            lastActiveLot.date,

                        type:
                            "buy",

                        amount:
                            lastActiveLot.amount,

                        price:
                            lastActiveLot.price
                    }
                ],
                currentPrice,
                today,
                annualBankRate
            );


        displaySection(
            lastPeriod,
            "last"
        );

    }


    /* IN / OUT */

    const lastTransaction =
        transactions.length > 0
        ?
        transactions[
            transactions.length - 1
        ]
        :
        null;


    const lastAction =
        document.getElementById(
            "lastAction"
        );


    if (
        lastTransaction
    ) {

        if (
            lastTransaction.type ===
            "buy"
        ) {

            lastAction.textContent =
                "IN";

            lastAction.className =
                "action-badge action-in";

        }

        else {

            lastAction.textContent =
                "OUT";

            lastAction.className =
                "action-badge action-out";

        }

    }


    document.getElementById(
        "loading"
    ).style.display =
        "none";


    document.getElementById(
        "dashboard"
    ).style.display =
        "grid";

}


/* START */

init()
.catch(
    error => {

        console.error(error);

        document.getElementById(
            "loading"
        ).style.display =
            "none";


        document.getElementById(
            "errorBox"
        ).innerHTML =

            '<div class="error">' +
            error.message +
            '</div>';

    }
);

</script>

</body>
</html>
