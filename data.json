<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Investment Dashboard</title>

<style>
* {
    box-sizing: border-box;
}

html, body {
    margin: 0;
    width: 100%;
    min-height: 100%;
}

body {
    font-family: "Segoe UI", Arial, sans-serif;
    color: #f8fafc;
    background:
        radial-gradient(circle at 10% 10%, rgba(37,99,235,.16), transparent 30%),
        radial-gradient(circle at 90% 20%, rgba(14,165,233,.10), transparent 30%),
        linear-gradient(135deg, #070b14, #0b1220, #0f172a);
}

.container {
    width: 100%;
    max-width: 1450px;
    margin: auto;
    padding: 14px 18px 18px;
}

/* HEADER */

header {
    padding: 14px 18px;
    margin-bottom: 12px;
    border-radius: 17px;
    background: rgba(255,255,255,.045);
    border: 1px solid rgba(255,255,255,.08);
    box-shadow: 0 15px 40px rgba(0,0,0,.25);
    backdrop-filter: blur(15px);
}

.header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

h1 {
    margin: 0;
    font-size: 25px;
    font-weight: 800;
}

.today {
    margin-top: 3px;
    color: #a5b4fc;
    font-size: 13px;
}

.live-price {
    margin-top: 11px;
    padding: 10px 15px;
    border-radius: 13px;
    background: rgba(2,6,23,.55);
    border: 1px solid rgba(255,255,255,.06);

    display: flex;
    align-items: center;
    justify-content: space-between;
}

.live-label {
    color: #94a3b8;
    font-size: 12px;
}

.live-number {
    margin-top: 2px;
    font-size: 28px;
    font-weight: 850;
}

.live-footer {
    color: #94a3b8;
    font-size: 13px;
}

/* ERROR */

.error {
    padding: 12px;
    margin-bottom: 12px;
    border-radius: 10px;
    color: #f87171;
    background: rgba(239,68,68,.10);
    border: 1px solid rgba(239,68,68,.25);
}

/* DASHBOARD */

#dashboard {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
}

/* CARD */

.card {
    min-width: 0;
    padding: 12px;
    border-radius: 17px;
    background: linear-gradient(
        145deg,
        rgba(255,255,255,.065),
        rgba(255,255,255,.025)
    );
    border: 1px solid rgba(255,255,255,.08);
    box-shadow: 0 12px 35px rgba(0,0,0,.22);
    backdrop-filter: blur(12px);
}

.card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 9px;
}

.card-title {
    font-size: 17px;
    font-weight: 800;
}

.period-info {
    display: flex;
    align-items: center;
    gap: 6px;
}

.trade-count {
    color: #64748b;
    font-size: 9px;
    white-space: nowrap;
}

.action-badge {
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 9px;
    font-weight: 850;
    letter-spacing: .5px;
}

.action-in {
    color: #67e8f9;
    background: rgba(34,211,238,.10);
    border: 1px solid rgba(34,211,238,.20);
}

.action-out {
    color: #fbbf24;
    background: rgba(245,158,11,.10);
    border: 1px solid rgba(245,158,11,.20);
}

/* MAIN PRICE */

.main-price {
    min-height: 158px;
    padding: 9px;
    margin-bottom: 9px;
    border-radius: 13px;

    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;

    transition: .3s;
}

.status-green {
    background:
        linear-gradient(
            135deg,
            rgba(16,185,129,.18),
            rgba(16,185,129,.035)
        );
    border: 1px solid rgba(16,185,129,.32);
}

.status-red {
    background:
        linear-gradient(
            135deg,
            rgba(239,68,68,.18),
            rgba(239,68,68,.035)
        );
    border: 1px solid rgba(239,68,68,.32);
}

.main-price-title {
    color: #94a3b8;
    font-size: 12px;
}

.main-price-number {
    margin-top: 2px;
    font-size: 27px;
    font-weight: 850;
}

/* P/L */

.pl-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 7px;
    margin-top: 8px;
}

.pl-box {
    height: 56px;
    padding: 6px;

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    border-radius: 9px;
    background: rgba(2,6,23,.38);
    border: 1px solid rgba(255,255,255,.09);
}

.pl-label {
    color: #94a3b8;
    font-size: 9px;
}

.pl-value {
    margin-top: 3px;
    font-size: 17px;
    font-weight: 850;
}

.profit {
    color: #34d399;
}

.loss {
    color: #f87171;
}

.result {
    margin-top: 7px;
    font-size: 9px;
    font-weight: 750;
}

/* COMPARISON */

.comparison {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 7px;
}

.compare-box {
    padding: 9px;
    border-radius: 9px;
    background: rgba(255,255,255,.035);
    border: 1px solid rgba(255,255,255,.055);
}

.compare-label {
    color: #94a3b8;
    font-size: 10px;
}

.compare-value {
    margin-top: 4px;
    font-size: 16px;
    font-weight: 800;
    white-space: nowrap;
}

/* METRICS */

.metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 7px;
    margin-top: 7px;
}

.metric {
    padding: 8px;
    min-height: 58px;
    border-radius: 9px;
    background: rgba(255,255,255,.035);
    border: 1px solid rgba(255,255,255,.055);
}

.metric-label {
    color: #94a3b8;
    font-size: 10px;
}

.metric-value {
    margin-top: 4px;
    font-size: 15px;
    font-weight: 750;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* DESKTOP */

@media (min-width: 1100px) {

    body {
        overflow-y: hidden;
    }

    .container {
        height: 100vh;
        display: flex;
        flex-direction: column;
    }

    header {
        flex-shrink: 0;
    }

    #dashboard {
        flex: 1;
        min-height: 0;
    }
}

/* TABLET */

@media (max-width: 1099px) {

    body {
        overflow-y: auto;
    }

    #dashboard {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

/* MOBILE */

@media (max-width: 650px) {

    .container {
        padding: 9px 8px 25px;
    }

    h1 {
        font-size: 21px;
    }

    .live-price {
        display: block;
    }

    .live-footer {
        margin-top: 5px;
    }

    #dashboard {
        grid-template-columns: 1fr;
    }

    /* Overall first */
    .card:nth-child(1) {
        order: 1;
    }

    /* Last 6 second */
    .card:nth-child(2) {
        order: 2;
    }

    /* Last Period third */
    .card:nth-child(3) {
        order: 3;
    }
}
</style>
</head>

