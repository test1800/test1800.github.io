<script>

/* =====================================
   FORMAT
===================================== */

function formatNumber(value) {

    if (
        value === null ||
        value === undefined ||
        !Number.isFinite(value)
    ) {
        return "-";
    }

    return Math.round(value)
        .toLocaleString("en-US");
}


function formatPercent(value) {

    if (!Number.isFinite(value)) {
        return "-";
    }

    const sign =
        value >= 0
        ? "+"
        : "";

    return (
        sign +
        value.toFixed(2) +
        "%"
    );
}


/* =====================================
   DATE
===================================== */

function dateNumber(date) {

    const parts =
        date
        .split("/")
        .map(Number);

    return (
        parts[0] * 10000 +
        parts[1] * 100 +
        parts[2]
    );
}


function jalaliToGregorian(
    jy,
    jm,
    jd
) {

    jy -= 979;

    let days =
        365 * jy +
        Math.floor(jy / 33) * 8 +
        Math.floor(
            ((jy % 33) + 3) / 4
        );

    for (
        let i = 1;
        i < jm;
        i++
    ) {

        days +=
            i <= 6
            ? 31
            : 30;

    }

    days +=
        jd - 1;

    let gy =
        1600 +
        400 *
        Math.floor(
            days / 146097
        );

    days %= 146097;

    if (days > 36524) {

        gy +=
            100 *
            Math.floor(
                --days / 36524
            );

        days %= 36524;

        if (days >= 365) {
            days++;
        }

    }

    gy +=
        4 *
        Math.floor(
            days / 1461
        );

    days %= 1461;

    if (days > 365) {

        gy +=
            Math.floor(
                (days - 1) / 365
            );

        days =
            (days - 1) % 365;

    }

    let gd =
        days + 1;

    const leap =
        (
            gy % 4 === 0 &&
            gy % 100 !== 0
        )
        ||
        gy % 400 === 0;

    const monthDays = [

        0,
        31,
        leap ? 29 : 28,
        31,
        30,
        31,
        30,
        31,
        31,
        30,
        31,
        30,
        31

    ];

    let gm = 1;

    while (
        gd >
        monthDays[gm]
    ) {

        gd -=
            monthDays[gm];

        gm++;

    }

    return new Date(
        gy,
        gm - 1,
        gd
    );
}


function daysBetweenInclusive(
    start,
    end
) {

    const s =
        start
        .split("/")
        .map(Number);

    const e =
        end
        .split("/")
        .map(Number);

    const startDate =
        jalaliToGregorian(
            s[0],
            s[1],
            s[2]
        );

    const endDate =
        jalaliToGregorian(
            e[0],
            e[1],
            e[2]
        );

    return Math.max(
        1,
        Math.floor(
            (
                endDate -
                startDate
            ) /
            86400000
        ) + 1
    );
}


/* =====================================
   BANK COMPOUND INTEREST
===================================== */

function calculateBankValue(
    principal,
    startDate,
    today,
    annualRate
) {

    const days =
        daysBetweenInclusive(
            startDate,
            today
        );

    const dailyRate =
        annualRate /
        100 /
        365;

    return (
        principal *
        Math.pow(
            1 + dailyRate,
            days
        )
    );
}


/* =====================================
   FIFO CALCULATION
===================================== */

function calculateFIFO(
    transactions,
    currentPrice,
    today,
    annualRate
) {

    const lots = [];

    let buyCount = 0;
    let sellCount = 0;

    for (
        const transaction
        of transactions
    ) {

        const amount =
            Number(
                transaction.amount
            );

        const price =
            Number(
                transaction.price
            );

        if (
            transaction.type === "buy"
        ) {

            buyCount++;

            lots.push({

                amount:
                    amount,

                price:
                    price,

                date:
                    transaction.date

            });

        }


        else if (
            transaction.type === "sell"
        ) {

            sellCount++;

            let remaining =
                amount;


            while (
                remaining > 0 &&
                lots.length > 0
            ) {

                const lot =
                    lots[0];


                if (
                    lot.amount <=
                    remaining
                ) {

                    remaining -=
                        lot.amount;

                    lots.shift();

                }

                else {

                    lot.amount -=
                        remaining;

                    remaining = 0;

                }

            }

        }

    }


    let currentQuantity = 0;

    let paidAmount = 0;

    let bankValue = 0;


    for (
        const lot
        of lots
    ) {

        currentQuantity +=
            lot.amount;


        paidAmount +=
            lot.amount *
            lot.price;


        bankValue +=
            calculateBankValue(
                lot.amount *
                lot.price,
                lot.date,
                today,
                annualRate
            );

    }


    const averagePurchasePrice =
        currentQuantity > 0
        ?
        paidAmount /
        currentQuantity
        :
        0;


    const currentValue =
        currentQuantity *
        currentPrice;


    const bankAdjustedPrice =
        currentQuantity > 0
        ?
        bankValue /
        currentQuantity
        :
        0;


    const plPurchase =
        averagePurchasePrice > 0
        ?
        (
            (
                currentPrice -
                averagePurchasePrice
            )
            /
            averagePurchasePrice
        )
        * 100
        :
        0;


    const plBank =
        bankValue > 0
        ?
        (
            (
                currentValue -
                bankValue
            )
            /
            bankValue
        )
        * 100
        :
        0;


    return {

        currentQuantity,

        paidAmount,

        averagePurchasePrice,

        bankAdjustedPrice,

        currentValue,

        bankValue,

        difference:
            currentValue -
            bankValue,

        plPurchase,

        plBank,

        buyCount,

        sellCount,

        lots

    };

}


/* =====================================
   DISPLAY
===================================== */

function displaySection(
    result,
    prefix,
    currentPrice
) {

    document.getElementById(
        prefix +
        "Average"
    ).textContent =
        formatNumber(
            result.averagePurchasePrice
        );


    document.getElementById(
        prefix +
        "Paid"
    ).textContent =
        formatNumber(
            result.paidAmount
        );


    document.getElementById(
        prefix +
        "Adjusted"
    ).textContent =
        formatNumber(
            result.bankAdjustedPrice
        );


    document.getElementById(
        prefix +
        "Quantity"
    ).textContent =
        formatNumber(
            result.currentQuantity
        );


    document.getElementById(
        prefix +
        "Value"
    ).textContent =
        formatNumber(
            result.currentValue
        );


    document.getElementById(
        prefix +
        "Bank"
    ).textContent =
        formatNumber(
            result.bankValue
        );


    document.getElementById(
        prefix +
        "Difference"
    ).textContent =
        formatNumber(
            Math.abs(
                result.difference
            )
        );


    const purchasePL =
        document.getElementById(
            prefix +
            "PLPurchase"
        );


    const bankPL =
        document.getElementById(
            prefix +
            "PLBank"
        );


    purchasePL.textContent =
        formatPercent(
            result.plPurchase
        );


    bankPL.textContent =
        formatPercent(
            result.plBank
        );


    purchasePL.className =
        "pl-value " +
        (
            result.plPurchase >= 0
            ?
            "profit"
            :
            "loss"
        );


    bankPL.className =
        "pl-value " +
        (
            result.plBank >= 0
            ?
            "profit"
            :
            "loss"
        );


    const mainPrice =
        document.getElementById(
            prefix +
            "MainPrice"
        );


    const resultText =
        document.getElementById(
            prefix +
            "Result"
        );


    mainPrice.classList.remove(
        "status-green",
        "status-red"
    );


    /*
       اگر قیمت محاسباتی با سود بانکی
       کمتر از قیمت آنلاین باشد:

       سرمایه‌گذاری بهتر از بانک
       => سبز

       در غیر این صورت:
       بانک بهتر است
       => قرمز
    */

    if (
        result.bankAdjustedPrice <
        currentPrice
    ) {

        mainPrice.classList.add(
            "status-green"
        );

        resultText.textContent =
            "INVESTMENT IS BETTER THAN BANK";

        resultText.style.color =
            "#34d399";

    }

    else {

        mainPrice.classList.add(
            "status-red"
        );

        resultText.textContent =
            "BANK RETURN IS BETTER THAN INVESTMENT";

        resultText.style.color =
            "#f87171";

    }


    const trades =
        document.getElementById(
            prefix +
            "Trades"
        );


    if (trades) {

        trades.textContent =
            result.buyCount +
            " IN  •  " +
            result.sellCount +
            " OUT";

    }

}


/* =====================================
   NOBITEX
===================================== */

async function getCurrentPrice(
    apiUrl,
    divisor
) {

    const response =
        await fetch(
            apiUrl +
            "?_=" +
            Date.now(),
            {
                method: "GET",
                cache: "no-store"
            }
        );


    if (
        !response.ok
    ) {

        throw new Error(
            "Unable to get current price"
        );

    }


    const data =
        await response.json();


    const lastTradePrice =
        Number(
            data.lastTradePrice
        );


    if (
        !Number.isFinite(
            lastTradePrice
        )
    ) {

        throw new Error(
            "lastTradePrice not found"
        );

    }


    return (
        lastTradePrice /
        divisor
    );

}


/* =====================================
   MAIN
===================================== */

async function init() {

    /*
       Load data.json
    */

    const response =
        await fetch(
            "data.json?_=" +
            Date.now()
        );


    if (
        !response.ok
    ) {

        throw new Error(
            "Cannot load data.json"
        );

    }


    const data =
        await response.json();


    const annualBankRate =
        Number(
            data.annualBankRate ||
            40
        );


    const divisor =
        Number(
            data.priceDivisor ||
            10
        );


    /*
       Get live price
    */

    const currentPrice =
        await getCurrentPrice(
            data.priceApi,
            divisor
        );


    const today =
        getTodayJalali();


    document.getElementById(
        "today"
    ).textContent =
        today;


    document.getElementById(
        "currentPrice"
    ).textContent =
        formatNumber(
            currentPrice
        );


    document.getElementById(
        "bankRate"
    ).textContent =
        annualBankRate +
        "%";


    /*
       Sort transactions
    */

    const transactions =
        Array.isArray(
            data.transactions
        )
        ?
        data.transactions
            .slice()
            .sort(
                (
                    a,
                    b
                ) =>
                    dateNumber(
                        a.date
                    )
                    -
                    dateNumber(
                        b.date
                    )
            )
        :
        [];


    if (
        transactions.length === 0
    ) {

        throw new Error(
            "No transactions found"
        );

    }


    /*
       OVERALL
    */

    const overall =
        calculateFIFO(
            transactions,
            currentPrice,
            today,
            annualBankRate
        );


    displaySection(
        overall,
        "overall",
        currentPrice
    );


    /*
       LAST 6 PERIODS

       آخرین 6 تراکنش
       فروش آخر هم در نظر گرفته می‌شود
    */

    const lastSix =
        transactions.slice(-6);


    const six =
        calculateFIFO(
            lastSix,
            currentPrice,
            today,
            annualBankRate
        );


    displaySection(
        six,
        "six",
        currentPrice
    );


    /*
       LAST PERIOD

       اگر آخرین تراکنش OUT باشد،
       از آخرین IN فعال به عقب می‌رویم.

       اما فروش آخر را حذف نمی‌کنیم.
       بنابراین ابتدا آخرین IN را پیدا می‌کنیم
       و سپس همه تراکنش‌ها از آن IN تا آخر
       را برای FIFO محاسبه می‌کنیم.
    */

    const lastTransaction =
        transactions[
            transactions.length - 1
        ];


    let lastStartIndex =
        transactions.length - 1;


    /*
       اگر آخرین تراکنش OUT است،
       آخرین IN قبل از آن را پیدا کن
    */

    if (
        lastTransaction.type ===
        "sell"
    ) {

        for (
            let i =
                transactions.length - 1;

            i >= 0;

            i--
        ) {

            if (
                transactions[i].type ===
                "buy"
            ) {

                lastStartIndex = i;

                break;

            }

        }

    }


    /*
       Last Period transactions

       از آخرین IN تا آخرین تراکنش
    */

    const lastPeriodTransactions =
        transactions.slice(
            lastStartIndex
        );


    const lastPeriod =
        calculateFIFO(
            lastPeriodTransactions,
            currentPrice,
            today,
            annualBankRate
        );


    displaySection(
        lastPeriod,
        "last",
        currentPrice
    );


    /*
       LAST ACTION
    */

    const action =
        document.getElementById(
            "lastAction"
        );


    if (
        lastTransaction.type ===
        "buy"
    ) {

        action.textContent =
            "IN";

        action.className =
            "action-badge action-in";

    }

    else {

        action.textContent =
            "OUT";

        action.className =
            "action-badge action-out";

    }


    /*
       اگر آخرین دوره فروش بوده،
       متن مشخص شود
    */

    const lastResult =
        document.getElementById(
            "lastResult"
        );


    if (
        lastTransaction.type ===
        "sell"
    ) {

        lastResult.textContent =
            "LAST PERIOD WAS OUT";

        lastResult.style.color =
            "#fbbf24";

    }


    /*
       SHOW
    */

    document.getElementById(
        "loading"
    ).style.display =
        "none";


    document.getElementById(
        "dashboard"
    ).style.display =
        "grid";

}


/* =====================================
   START
===================================== */

init()
.catch(
    error => {

        console.error(
            error
        );


        document.getElementById(
            "loading"
        ).style.display =
            "none";


        document.getElementById(
            "errorBox"
        ).innerHTML =

            '<div class="error">' +
            error.message +
            '</div>';

    }
);

</script>

</body>
</html>
